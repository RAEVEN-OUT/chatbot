APP_NAME=Multi Site FAQ Chatbot
ENV=development
STORAGE_BACKEND=memory

# Set this in production. When empty, admin routes are open for local dev.
ADMIN_API_KEY=

# Firestore is only used when STORAGE_BACKEND=firestore.
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE=(default)

# Hosted embeddings are optional. OpenAI is preferred when OPENAI_API_KEY is set.
# Never commit a real key; put it only in your local .env or deployment secrets.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Keep 768 unless you rebuild your Firestore vector index and reindex all FAQs.
OPENAI_EMBEDDING_DIMENSIONS=768

# Gemini can still be used for embeddings when OpenAI is not configured.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Firestore/site/vector caches are process-local and invalidated on admin writes.
REPOSITORY_CACHE_TTL_SECONDS=60
REPOSITORY_CACHE_MAX_ITEMS=1000
EMBEDDING_CACHE_TTL_SECONDS=86400
EMBEDDING_CACHE_MAX_ITEMS=5000

# Comma-separated list or * for dev.
ALLOWED_ORIGINS=*
VECTOR_SEARCH_LIMIT=5
